---
import Layout from './Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  category: string
  date: string
  readTime: string
  heroTitle: string
  heroSubtitle?: string
  /** ISO 8601 date for SEO. Falls back to today if not provided. */
  datePublished?: string
  image?: string
}

const {
  title,
  description,
  category,
  date,
  readTime,
  heroTitle,
  heroSubtitle,
  datePublished,
  image = '/hero-canigou.webp',
} = Astro.props

const siteUrl = Astro.site ?? new URL('https://comroussillon.fr')
const url = new URL(Astro.url.pathname, siteUrl).toString()

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: heroTitle,
  description,
  image: new URL(image, siteUrl).toString(),
  url,
  mainEntityOfPage: url,
  articleSection: category,
  datePublished: datePublished ?? new Date().toISOString(),
  author: { '@type': 'Organization', name: 'Com Roussillon' },
  publisher: {
    '@type': 'Organization',
    name: 'Com Roussillon',
    logo: { '@type': 'ImageObject', url: new URL('/logo-comroussillon.webp', siteUrl).toString() },
  },
}
---

<Layout title={title} description={description} type="article" image={image} jsonLd={blogPosting}>
  <Nav />

  <div class="read-progress" id="readProgress"></div>

  <div class="article-hero">
    <div class="article-hero-inner">
      <span class="article-category">{category}</span>
      <h1>{heroTitle}</h1>
      {heroSubtitle && <p class="article-subtitle">{heroSubtitle}</p>}
      <div class="article-meta">
        <span>{date}</span>
        <span class="meta-sep">·</span>
        <span>{readTime} de lecture</span>
      </div>
    </div>
  </div>

  <main id="main" class="article-main">
    <div class="article-content">
      <slot />
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .read-progress {
    position: fixed;
    top: 0; left: 0;
    height: 5px;
    background: var(--gold);
    width: 0%;
    z-index: 9999;
    transition: width .1s linear;
    box-shadow: 0 0 10px rgba(245,166,35,0.45);
  }

  /* Hero */
  .article-hero {
    background: var(--dark);
    position: relative;
    overflow: hidden;
    padding: 7rem 5vw 5rem;
  }
  .article-hero::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 600px; height: 100%;
    background: radial-gradient(ellipse at top right, rgba(245,166,35,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .article-hero-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }
  .article-category {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(245,166,35,0.12);
    border: 1px solid rgba(245,166,35,0.25);
    padding: .3rem .75rem;
    border-radius: 20px;
    margin-bottom: 1.4rem;
  }
  .article-hero h1 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.12;
    letter-spacing: -.03em;
    margin-bottom: 1.2rem;
    max-width: 820px;
  }
  .article-subtitle {
    font-size: 16px;
    font-weight: 300;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    margin-bottom: 1.8rem;
    max-width: 620px;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    letter-spacing: .02em;
  }
  .meta-sep { color: rgba(255,255,255,0.2) }

  /* Contenu */
  .article-main {
    background: #f2f2f5;
    padding: 5rem 5vw 7rem;
  }

  .article-content {
    max-width: 900px;
    margin: 0 auto;
    counter-reset: section;
  }

  /* Premier paragraphe intro — fond blanc, grande typo */
  .article-content :global(p:first-of-type) {
    font-size: 18px;
    color: #1d1d1f;
    line-height: 1.8;
    letter-spacing: -.015em;
    margin-bottom: 3rem;
    padding: 2rem 2.4rem;
    background: #fff;
    border-radius: 14px;
    border-left: 4px solid var(--gold);
    box-shadow: 0 2px 16px rgba(0,0,0,.05);
  }

  /* Sections h2 avec numéro cerclé */
  .article-content :global(h2) {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--dark);
    letter-spacing: -.025em;
    line-height: 1.25;
    margin: 4rem 0 1.4rem;
  }
  .article-content :global(h2)::before {
    counter-increment: section;
    content: counter(section);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    background: var(--gold);
    color: #fff;
    border-radius: 50%;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0;
    flex-shrink: 0;
  }

  /* Bloc de section : fond blanc, padding, radius */
  .article-content :global(h2 + p),
  .article-content :global(h2 + ul),
  .article-content :global(h2 + ol) {
    background: #fff;
    border-radius: 0 0 14px 14px;
    padding: 1.6rem 2rem 1.6rem calc(36px + 14px + 2rem);
    margin-top: -0.6rem;
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
  }

  .article-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--dark);
    letter-spacing: -.02em;
    line-height: 1.3;
    margin: 2rem 0 .6rem;
  }

  .article-content :global(p) {
    font-size: 16px;
    line-height: 1.85;
    color: #3a3a3c;
    margin-bottom: 1.3rem;
    letter-spacing: -.01em;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 0;
    margin-bottom: 1.4rem;
    list-style: none;
  }
  .article-content :global(ul li),
  .article-content :global(ol li) {
    font-size: 15.5px;
    line-height: 1.75;
    color: #3a3a3c;
    margin-bottom: .7rem;
    padding-left: 1.6rem;
    position: relative;
  }
  .article-content :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0; top: .65em;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--gold);
  }
  .article-content :global(ol) { counter-reset: item }
  .article-content :global(ol li::before) {
    content: counter(item);
    counter-increment: item;
    position: absolute;
    left: 0;
    font-size: 12px;
    font-weight: 800;
    color: var(--gold);
    top: .2em;
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: #1d1d1f;
  }
  .article-content :global(a) {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(245,166,35,0.35);
    transition: text-decoration-color .2s;
  }
  .article-content :global(a:hover) {
    text-decoration-color: var(--gold);
  }

  /* Blockquote */
  .article-content :global(blockquote) {
    margin: 2.5rem 0;
    padding: 1.6rem 2rem;
    border-left: 4px solid var(--gold);
    background: #fff;
    border-radius: 0 14px 14px 0;
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
  }
  .article-content :global(blockquote p) {
    font-size: 17px;
    font-style: italic;
    color: #2a2a2c;
    margin: 0;
    line-height: 1.7;
  }

  /* CTA block — override le compteur */
  .article-content :global(.cta-block) {
    background: var(--dark);
    border-radius: 18px;
    padding: 3rem 2.8rem;
    margin-top: 4rem;
    text-align: center;
    box-shadow: none;
  }
  .article-content :global(.cta-block h2) {
    display: block;
    color: #fff;
    font-size: 1.35rem;
    margin: 0 0 .7rem;
    letter-spacing: -.02em;
  }
  .article-content :global(.cta-block h2)::before {
    display: none;
  }
  .article-content :global(.cta-block p) {
    color: rgba(255,255,255,0.65);
    font-size: 15px;
    margin-bottom: 1.6rem;
    padding: 0; background: none;
    border: none; box-shadow: none;
    font-size: 15px;
  }
  .article-content :global(.cta-block a.btn-gold) {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    padding: .78rem 1.8rem;
    border-radius: 980px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity .2s;
  }
  .article-content :global(.cta-block a.btn-gold:hover) { opacity: .85 }

  @media (max-width: 768px) {
    .article-hero { padding: 5rem 5vw 3.5rem }
    .article-main { padding: 3rem 4vw 5rem }
    .article-content :global(h2) {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
    }
    .article-content :global(p:first-of-type) {
      font-size: 16px;
      padding: 1.4rem 1.4rem;
    }
    .article-content :global(h2 + p),
    .article-content :global(h2 + ul),
    .article-content :global(h2 + ol) {
      padding: 1.2rem 1.2rem 1.2rem 1.4rem;
    }
    .article-content :global(.cta-block) { padding: 2rem 1.4rem }
  }
</style>

<script>
  const bar = document.getElementById('readProgress')
  const content = document.querySelector('.article-main')
  if (bar && content) {
    window.addEventListener('scroll', () => {
      const total = (content as HTMLElement).offsetHeight - window.innerHeight
      const scrolled = Math.max(0, window.scrollY - (content as HTMLElement).offsetTop)
      bar.style.width = Math.min(100, (scrolled / total) * 100) + '%'
    }, { passive: true })
  }
</script>
