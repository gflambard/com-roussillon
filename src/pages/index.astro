---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Services from '../components/Services.astro'
import Pourquoi from '../components/Pourquoi.astro'
import Realisations from '../components/Realisations.astro'
import RealisationsAutres from '../components/RealisationsAutres.astro'
import BrancheDev from '../components/BrancheDev.astro'
import Avis from '../components/Avis.astro'
import Partenaires from '../components/Partenaires.astro'
import Contact from '../components/Contact.astro'
import FAQ from '../components/FAQ.astro'
import Footer from '../components/Footer.astro'
---

<Layout>
  <Nav />
  <main id="main">
    <Hero />
    <Services />
    <Pourquoi />
    <Realisations />
    <RealisationsAutres />
    <BrancheDev />
    <Avis />
    <Partenaires />
    <Contact />
    <FAQ />
  </main>
  <Footer />
</Layout>

<script>
// Fade-up intersection observer
const fadeObs = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 70)
      fadeObs.unobserve(e.target)
    }
  })
}, { threshold: 0.08 })
document.querySelectorAll('.fade-up').forEach(el => fadeObs.observe(el))

// Carrousel scroll-snap natif — boutons + dots synchronisés au scrollLeft
function initCarousel(name: string) {
  const scroller = document.querySelector<HTMLElement>(`[data-carousel="${name}"]`)
  const dotsEl = document.querySelector<HTMLElement>(`[data-carousel-dots="${name}"]`)
  const prev = document.querySelector<HTMLButtonElement>(`[data-carousel-prev="${name}"]`)
  const next = document.querySelector<HTMLButtonElement>(`[data-carousel-next="${name}"]`)
  if (!scroller || !dotsEl) return

  const cards = Array.from(scroller.children) as HTMLElement[]
  if (cards.length === 0) return

  dotsEl.innerHTML = ''
  const dots = cards.map((_, i) => {
    const d = document.createElement('button')
    d.type = 'button'
    d.className = 'dot' + (i === 0 ? ' active' : '')
    d.setAttribute('aria-label', `Aller à l'élément ${i + 1}`)
    d.addEventListener('click', () => scrollToCard(i))
    dotsEl.appendChild(d)
    return d
  })

  const baseOffset = () => cards[0].offsetLeft

  function scrollToCard(i: number) {
    i = Math.max(0, Math.min(i, cards.length - 1))
    scroller!.scrollTo({ left: cards[i].offsetLeft - baseOffset(), behavior: 'smooth' })
  }

  function activeIndex() {
    const sl = scroller!.scrollLeft + baseOffset()
    let best = 0
    let bestDist = Infinity
    cards.forEach((c, i) => {
      const dist = Math.abs(c.offsetLeft - sl)
      if (dist < bestDist) { bestDist = dist; best = i }
    })
    return best
  }

  prev?.addEventListener('click', () => scrollToCard(activeIndex() - 1))
  next?.addEventListener('click', () => scrollToCard(activeIndex() + 1))

  let rafId = 0
  function sync() {
    cancelAnimationFrame(rafId)
    rafId = requestAnimationFrame(() => {
      const sl = scroller!.scrollLeft
      const max = scroller!.scrollWidth - scroller!.clientWidth
      prev?.classList.toggle('visible', sl > 4)
      next?.classList.toggle('visible', sl < max - 4)
      const i = activeIndex()
      dots.forEach((d, j) => d.classList.toggle('active', j === i))
    })
  }

  scroller.addEventListener('scroll', sync, { passive: true })
  window.addEventListener('resize', sync)
  sync()
}

window.addEventListener('load', () => {
  initCarousel('svc')
  initCarousel('real')
  initCarousel('ar')
})
</script>
