---
---

<div class="cookie-banner" id="cookieBanner" role="dialog" aria-labelledby="cookieTitle" aria-describedby="cookieDesc" hidden>
  <div class="cookie-inner">
    <div class="cookie-text">
      <strong id="cookieTitle">Cookies & mesure d'audience</strong>
      <p id="cookieDesc">Nous utilisons Google Analytics pour comprendre comment vous naviguez sur le site et améliorer notre service. Aucune donnée n'est utilisée à des fins publicitaires.</p>
    </div>
    <div class="cookie-actions">
      <button type="button" class="cookie-btn cookie-refuse" id="cookieRefuse">Refuser</button>
      <button type="button" class="cookie-btn cookie-accept" id="cookieAccept">Accepter</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 16px;
    left: 16px;
    right: 16px;
    z-index: 9998;
    background: #fff;
    border: 0.5px solid rgba(0,0,0,0.1);
    border-radius: 14px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.18);
    padding: 1.1rem 1.3rem;
    max-width: 760px;
    margin: 0 auto;
    animation: cookie-in .4s ease;
  }
  @keyframes cookie-in { from { opacity: 0; transform: translateY(12px) } to { opacity: 1; transform: translateY(0) } }
  .cookie-inner {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .cookie-text { flex: 1; min-width: 240px }
  .cookie-text strong {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: .2rem;
    letter-spacing: -.01em;
  }
  .cookie-text p {
    font-size: 13px;
    font-weight: 300;
    color: #515154;
    line-height: 1.55;
    letter-spacing: -.01em;
  }
  .cookie-actions { display: flex; gap: .6rem; flex-wrap: wrap }
  .cookie-btn {
    border: none;
    cursor: pointer;
    padding: .58rem 1.2rem;
    border-radius: 980px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    transition: background .2s, border-color .2s;
    letter-spacing: -.01em;
  }
  .cookie-refuse {
    background: transparent;
    color: #515154;
    border: 0.5px solid #c7c7cc;
  }
  .cookie-refuse:hover { border-color: #515154 }
  .cookie-accept {
    background: #1d1d1f;
    color: #fff;
  }
  .cookie-accept:hover { background: #333 }

  @media (max-width: 640px) {
    .cookie-inner { flex-direction: column; align-items: stretch }
    .cookie-actions { justify-content: stretch }
    .cookie-actions .cookie-btn { flex: 1 }
  }
</style>

<script is:inline>
  (function () {
    var KEY = 'cr-consent-v1';
    var GA_ID = 'G-BLV3N7WTHD';
    var banner = document.getElementById('cookieBanner');

    function loadGtag() {
      if (window.__gaLoaded) return;
      window.__gaLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){ window.dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA_ID, { anonymize_ip: true });
    }

    function hide() { if (banner) banner.setAttribute('hidden', ''); }
    function show() { if (banner) banner.removeAttribute('hidden'); }

    var saved = null;
    try { saved = localStorage.getItem(KEY); } catch (e) {}

    if (saved === 'accepted') {
      loadGtag();
    } else if (saved === 'refused') {
      // do nothing
    } else {
      show();
    }

    document.getElementById('cookieAccept')?.addEventListener('click', function () {
      try { localStorage.setItem(KEY, 'accepted'); } catch (e) {}
      loadGtag();
      hide();
    });
    document.getElementById('cookieRefuse')?.addEventListener('click', function () {
      try { localStorage.setItem(KEY, 'refused'); } catch (e) {}
      hide();
    });
  })();
</script>
