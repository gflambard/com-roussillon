---
const services = [
  {
    tag: 'Nouveau service',
    title: 'Photo, vidéo & drone',
    tagline: 'Image. Mouvement. Hauteur.',
    desc: 'Captation pro de vos lieux, produits et terroir — photo, vidéo et vues aériennes par drone. Production locale en Roussillon.',
    img: '/drone.png',
    alt: 'Drone professionnel pour prise de vue aérienne à Perpignan',
    dark: true,
  },
  {
    tag: 'Populaire',
    title: 'Site web sur mesure',
    tagline: 'Rapide. Responsive. Optimisé SEO.',
    desc: 'Vitrine, e-commerce ou portfolio — conçu pour capter vos clients à Perpignan et en Roussillon.',
    img: '/site-web-mockup.webp',
    alt: 'Création de site web sur mesure par Com Roussillon',
  },
  {
    tag: 'Essentiel',
    title: 'Identité visuelle',
    tagline: 'Logo. Charte. Couleurs.',
    desc: 'Une identité forte qui vous distingue et reste mémorable — du logo à tous vos supports.',
    img: '/identite-visuelle.webp',
    alt: "Création d'identité visuelle et de logo pour entreprise",
    dark: true,
  },
  {
    tag: 'Tendance',
    title: 'Réseaux sociaux',
    tagline: 'Visuels. Publications. Stratégie.',
    desc: 'Une présence active sur Instagram, Facebook et LinkedIn — contenu sur mesure, aligné à votre image.',
    img: '/mockup-reseaux-sociaux.webp',
    alt: 'Gestion de réseaux sociaux Instagram et Facebook',
  },
  {
    tag: 'Complet',
    title: "Supports d'impression",
    tagline: 'Flyers. Affiches. Brochures.',
    desc: 'Impression haute qualité tous formats — cartes de visite, dépliants, livrets, calendriers.',
    img: '/carte-de-visite.webp',
    alt: 'Carte de visite et supports imprimés personnalisés',
    dark: true,
  },
  {
    tag: 'Sur-mesure',
    title: 'Vêtements personnalisés',
    tagline: 'Sérigraphie. Broderie. Flocage.',
    desc: 'T-shirts, polos, sweats à votre image — pour vos équipes, clubs sportifs ou événements.',
    img: '/vetement-personnalise.webp',
    alt: 'T-shirt et vêtement personnalisé pour entreprise et club sportif',
  },
  {
    tag: 'Stratégique',
    title: 'Audit & conseils',
    tagline: 'Diagnostic. Stratégie. Action.',
    desc: 'Un regard extérieur pour identifier ce qui bloque dans votre communication — et comment y remédier.',
    img: '/audit-et-conseils.webp',
    alt: 'Audit et conseils en stratégie de communication',
    dark: true,
  },
]
---

<section id="services">
  <div class="services-header fade-up">
    <span class="sec-label">Ce que nous faisons</span>
    <h2 class="sec-title">Tout ce dont vous avez<br>besoin, au même endroit.</h2>
    <p class="sec-intro">Six services complémentaires pour construire une communication cohérente, efficace et à votre image.</p>
  </div>

  <div class="carousel-wrap">
    <button class="carousel-nav-btn prev" data-carousel-prev="svc" aria-label="Précédent">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="carousel-nav-btn next" data-carousel-next="svc" aria-label="Suivant">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <div class="carousel-scroller services-track" data-carousel="svc">
      {services.map(s => (
        <article class={`svc-card${s.dark ? ' dark' : ''}`}>
          <div class="svc-text">
            <span class="svc-new">{s.tag}</span>
            <h3>{s.title}</h3>
            <p class="svc-tagline">{s.tagline}</p>
            <p class="svc-desc">{s.desc}</p>
          </div>
          <div class="svc-img">
            <img src={s.img} alt={s.alt} loading="lazy" decoding="async" />
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="carousel-dots-wrap">
    <div class="carousel-dots" data-carousel-dots="svc"></div>
  </div>
</section>

<style>
  #services { background: #fff; padding: 7rem 0 }
  .services-header { padding: 0 max(5vw, calc((100vw - 1200px) / 2)) 2.5rem }

  .svc-card {
    flex: 0 0 340px;
    height: 520px;
    background: #fff;
    border-radius: var(--radius);
    overflow: clip;
    position: relative;
    transition: transform .3s ease;
  }
  .svc-card:hover { transform: scale(1.02) }
  .svc-card.dark { background: var(--dark) }

  .svc-text { padding: 2.5rem 2rem 1rem; position: relative; z-index: 1 }

  .svc-new {
    font-size: 12px; font-weight: 600; color: var(--gold);
    letter-spacing: .05em; text-transform: uppercase; margin-bottom: 1rem; display: block;
  }
  .svc-card h3 {
    font-size: 26px; font-weight: 600; letter-spacing: -.03em;
    line-height: 1.1; color: var(--dark); margin-bottom: .6rem;
  }
  .svc-card.dark h3 { color: #fff }
  .svc-tagline { font-size: 15px; font-weight: 500; color: var(--dark); margin-bottom: .4rem; letter-spacing: -.02em }
  .svc-card.dark .svc-tagline { color: #f5f5f7 }
  .svc-desc { font-size: 13px; font-weight: 300; color: var(--light); line-height: 1.6; letter-spacing: -.01em }
  .svc-card.dark .svc-desc { color: #86868b }

  .svc-img {
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 320px; overflow: hidden;
    border-radius: 0 0 var(--radius) var(--radius);
  }
  .svc-img img {
    width: 100%; height: 100%;
    object-fit: contain; object-position: bottom center;
    display: block;
    transition: transform .4s ease;
  }
  .svc-card:hover .svc-img img { transform: scale(1.04) }

  @media (max-width: 768px) {
    .svc-card {
      flex: 0 0 calc(100vw - 4rem);
      height: 480px;
    }
    .svc-card:hover { transform: none }
    .svc-img { height: 280px }
  }
</style>
