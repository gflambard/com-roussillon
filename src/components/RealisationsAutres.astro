---
const cards = [
  {
    img: '/instagram-entente-de-la-tet.webp',
    alt: "Gestion du compte Instagram de l'Entente de la Têt par Com Roussillon",
    label: 'Entente de la Têt',
    tag: 'Réseaux sociaux',
  },
  {
    img: '/mockup-bouteille-xv-catalan.webp',
    alt: "Design d'étiquette de bouteille pour le XV Catalan",
    label: 'XV Catalan',
    tag: 'Design produit',
  },
  {
    img: '/impression-textile-spar.webp',
    alt: 'Impression textile et vêtements personnalisés pour Spar',
    label: 'Spar',
    tag: 'Textile personnalisé',
  },
  {
    img: '/impression-brochure.webp',
    alt: 'Conception et impression de brochure professionnelle',
    label: 'Impression',
    tag: 'Supports print',
  },
  {
    img: '/logo-garage-actipole.webp',
    alt: 'Logo du Garage Actipole créé par Com Roussillon',
    label: 'Garage Actipole',
    tag: 'Création de logo',
  },
]
---

<section id="autres-realisations">
  <div class="ar-header fade-up">
    <span class="sec-label">Nos réalisations</span>
    <h2 class="sec-title">Logos, print, réseaux,<br>textile — et plus encore.</h2>
    <p class="sec-intro">Un aperçu de nos créations au-delà du web — pour une communication complète et cohérente.</p>
  </div>

  <div class="carousel-wrap">
    <button class="carousel-nav-btn prev" data-carousel-prev="ar" aria-label="Précédent">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="carousel-nav-btn next" data-carousel-next="ar" aria-label="Suivant">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <div class="carousel-scroller ar-track" data-carousel="ar">
      {cards.map(c => (
        <div class="ar-card fade-up">
          <div class="ar-img-wrap">
            <img src={c.img} alt={c.alt} class="ar-img" loading="lazy" decoding="async" />
            <div class="ar-overlay">
              <strong>{c.label}</strong>
              <span>{c.tag}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="carousel-dots-wrap ar-dots-wrap">
    <div class="carousel-dots" data-carousel-dots="ar"></div>
  </div>
</section>

<style>
  #autres-realisations { background: var(--bg-off); padding: 3rem 0 7rem }
  .ar-header { padding: 0 max(5vw, calc((100vw - 1200px) / 2)) 2.5rem }
  .ar-header .sec-label { color: var(--gold) }
  .ar-dots-wrap { padding-top: 1.5rem }

  .ar-card { flex: 0 0 300px }
  .ar-img-wrap {
    width: 300px; height: 300px;
    border-radius: var(--radius);
    overflow: hidden; position: relative;
    background: #fff;
  }
  .ar-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
    transition: transform .4s ease;
  }
  .ar-card:hover .ar-img { transform: scale(1.05) }

  .ar-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.65) 0%, transparent 55%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 1.2rem 1.4rem;
    opacity: 0; transition: opacity .3s;
  }
  .ar-card:hover .ar-overlay { opacity: 1 }
  .ar-overlay strong { color: #fff; font-size: 14px; font-weight: 600; letter-spacing: -.02em }
  .ar-overlay span { color: rgba(255,255,255,.6); font-size: 11px }

  @media (max-width: 768px) {
    .ar-card { flex: 0 0 80vw }
    .ar-img-wrap { width: 100%; height: 80vw }
    .ar-overlay { opacity: 0.82 }
  }
</style>
