---
const projects = [
  {
    href: 'https://maillotfrancais.fr/',
    img: '/site-maillot-francais.webp',
    alt: 'Aperçu du site e-commerce Maillot Français réalisé par Com Roussillon',
    label: 'Maillot Français',
    tag: 'E-commerce',
  },
  {
    href: 'https://coteartwear.fr/',
    img: '/site-coteartwear.webp',
    alt: 'Aperçu du site e-commerce Côté Artwear, marque de vêtements',
    label: 'Côté Artwear',
    tag: 'E-commerce · Marque de vêtement',
  },
  {
    href: 'https://entente-de-la-tet.fr/',
    img: '/site-entente-de-la-tet.webp',
    alt: 'Aperçu du site vitrine du club de rugby Entente de la Têt',
    label: 'Entente de la Têt',
    tag: 'Site vitrine · Club de rugby',
  },
]
---

<section id="realisations">
  <div class="real-header fade-up">
    <span class="sec-label">Nos réalisations – Site web</span>
    <h2 class="sec-title">Des sites qui travaillent<br>pour vous, 24h/24.</h2>
    <p class="sec-intro">Vitrine, e-commerce ou club sportif — chaque site conçu sur mesure, à votre image.</p>
  </div>

  <div class="carousel-wrap">
    <button class="carousel-nav-btn prev" data-carousel-prev="real" aria-label="Précédent">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="carousel-nav-btn next" data-carousel-next="real" aria-label="Suivant">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <div class="carousel-scroller real-track" data-carousel="real">
      {projects.map(p => (
        <a class="real-card fade-up" href={p.href} target="_blank" rel="noopener noreferrer">
          <div class="real-img-wrap">
            <img src={p.img} alt={p.alt} class="real-img" loading="lazy" decoding="async" />
            <div class="real-overlay"><strong>{p.label}</strong><span>{p.tag}</span></div>
          </div>
          <div class="real-label"><strong>{p.label}</strong><span>{p.tag}</span></div>
        </a>
      ))}
    </div>
  </div>

  <div class="carousel-dots-wrap">
    <div class="carousel-dots" data-carousel-dots="real"></div>
  </div>
</section>

<style>
  #realisations { background: var(--bg-off); padding: 7rem 0 3rem }
  .real-header { padding: 0 max(5vw, calc((100vw - 1200px) / 2)) 2.5rem }

  .real-card {
    flex: 0 0 480px;
    border-radius: var(--radius);
    overflow: hidden;
    display: flex; flex-direction: column;
    background: #fff;
    text-decoration: none;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    transition: transform .25s, box-shadow .25s;
  }
  .real-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.13) }

  .real-img-wrap { height: 280px; overflow: hidden; position: relative; flex-shrink: 0 }
  .real-img {
    width: 100%; height: 100%;
    display: block; position: absolute; inset: 0;
    object-fit: cover; object-position: top center;
  }

  .real-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.55) 0%, transparent 55%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 1.4rem 1.6rem;
    opacity: 0; transition: opacity .3s;
  }
  .real-overlay strong { color: #fff; font-size: 15px; font-weight: 600; letter-spacing: -.02em }
  .real-overlay span { color: rgba(255,255,255,.65); font-size: 12px }
  .real-card:hover .real-overlay { opacity: 1 }

  .real-label { display: none }

  @media (max-width: 768px) {
    .real-card { flex: 0 0 calc(100vw - 4rem) }
    .real-img-wrap { height: 200px }
    .real-overlay { opacity: 0 !important }
    .real-label {
      display: flex; flex-direction: column;
      padding: .7rem 1rem;
      background: #fff;
      border-radius: 0 0 var(--radius) var(--radius);
    }
    .real-label strong { font-size: 13px; font-weight: 600; color: var(--dark); letter-spacing: -.01em }
    .real-label span { font-size: 11px; color: #86868b; font-weight: 300 }
  }
</style>
