---
---

<section id="realisations">
  <div class="real-header fade-up">
    <span class="sec-label">Nos réalisations – Site web</span>
    <h2 class="sec-title">Des sites qui travaillent<br>pour vous, 24h/24.</h2>
    <p class="sec-intro">Vitrine, e-commerce ou club sportif — chaque site conçu sur mesure, à votre image.</p>
  </div>
  <div class="real-track-wrap">
    <button class="real-nav-btn real-nav-prev" id="realPrev" aria-label="Précédent">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="real-nav-btn real-nav-next" id="realNext" aria-label="Suivant">
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="real-track" id="realTrack">

      <a class="real-card fade-up" href="https://maillotfrancais.fr/" target="_blank" rel="noopener">
        <div class="real-img-wrap">
          <img src="/site maillot francais.webp" alt="Maillot Français" class="real-img" />
          <div class="real-overlay"><strong>Maillot Français</strong><span>E-commerce</span></div>
        </div>
        <div class="real-label"><strong>Maillot Français</strong><span>E-commerce</span></div>
      </a>

      <a class="real-card fade-up" href="https://coteartwear.fr/" target="_blank" rel="noopener">
        <div class="real-img-wrap">
          <img src="/site coteartwear.webp" alt="Côté Artwear" class="real-img" />
          <div class="real-overlay"><strong>Côté Artwear</strong><span>E-commerce · Marque de vêtement</span></div>
        </div>
        <div class="real-label"><strong>Côté Artwear</strong><span>E-commerce · Marque de vêtement</span></div>
      </a>

      <a class="real-card fade-up" href="https://entente-de-la-tet.fr/" target="_blank" rel="noopener">
        <div class="real-img-wrap">
          <img src="/site entente de la têt.webp" alt="Entente de la Têt" class="real-img" />
          <div class="real-overlay"><strong>Entente de la Têt</strong><span>Site vitrine · Club de rugby</span></div>
        </div>
        <div class="real-label"><strong>Entente de la Têt</strong><span>Site vitrine · Club de rugby</span></div>
      </a>

    </div>
  </div>
  <div class="real-dots-wrap">
    <div class="carousel-dots" id="realDots"></div>
  </div>
</section>

<style>
#realisations { background: var(--bg-off); padding: 7rem 0 3rem }
.real-header { padding: 0 5vw 2.5rem }
.real-track-wrap { overflow-x: clip; overflow-y: visible; position: relative }

/* Boutons overlay sur le carrousel */
.real-nav-btn {
  position: absolute; top: 50%; transform: translateY(-60%);
  z-index: 10; width: 44px; height: 44px; border-radius: 50%;
  background: rgba(255,255,255,0.92); border: 0.5px solid rgba(0,0,0,0.1);
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: var(--dark); transition: opacity .2s, transform .2s, background .2s;
  opacity: 0; pointer-events: none;
}
.real-nav-btn.visible { opacity: 1; pointer-events: auto }
.real-nav-btn:hover { background: #fff; transform: translateY(-60%) scale(1.08) }
.real-nav-prev { left: 16px }
.real-nav-next { right: 16px }

.real-dots-wrap { padding: 1rem 0 0; display: flex; justify-content: center }
.real-track {
  display: flex; gap: 16px; padding: 0 0 2rem;
  padding-left: min(5vw, calc((100vw - 1200px) / 2 + 5vw));
  user-select: none;
  transition: transform .4s cubic-bezier(.25,.46,.45,.94);
}
.real-card {
  flex: 0 0 480px;
  border-radius: var(--radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #fff;
  text-decoration: none;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  transition: transform .25s, box-shadow .25s;
  flex-shrink: 0;
}
.real-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.13) }

.real-img-wrap {
  height: 280px;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}
.real-img {
  width: 100%; height: 100%;
  display: block;
  position: absolute; inset: 0;
  object-fit: cover;
  object-position: top center;
}


.real-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.55) 0%, transparent 55%);
  display: flex; flex-direction: column; justify-content: flex-end; padding: 1.4rem 1.6rem;
  opacity: 0; transition: opacity .3s;
}
.real-overlay strong { color: #fff; font-size: 15px; font-weight: 600; letter-spacing: -.02em }
.real-overlay span { color: rgba(255,255,255,.65); font-size: 12px }
.real-card:hover .real-overlay { opacity: 1 }

.real-label { display: none }

@media (max-width: 768px) {
  .real-track { padding-left: 1rem; gap: 12px }
  .real-card { flex: 0 0 calc(100vw - 2rem) }
  .real-img-wrap { height: 200px }
  .real-overlay { opacity: 0 !important }
  .real-label {
    display: flex; flex-direction: column;
    padding: .7rem 1rem;
    background: #fff;
    border-radius: 0 0 var(--radius) var(--radius);
  }
  .real-label strong { font-size: 13px; font-weight: 600; color: var(--dark); letter-spacing: -.01em }
  .real-label span { font-size: 11px; color: #86868b; font-weight: 300 }
}
</style>
