<section id="contact" class="sec">
  <div class="sec-inner">
    <div class="contact-grid">

      <div class="contact-info fade-up">
        <span class="sec-label">Contact</span>
        <h2>Un projet ?<br>Parlons-en.</h2>
        <p>Devis gratuit et sans engagement. On répond sous 24h et on prend le temps de comprendre votre besoin avant de proposer quoi que ce soit.</p>

        <div class="cd">
          <div class="cd-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M2 3.5h12a.5.5 0 01.5.5v8a.5.5 0 01-.5.5H2a.5.5 0 01-.5-.5V4a.5.5 0 01.5-.5z" stroke="#888" stroke-width="1.1"/>
              <path d="M1.5 4.5L8 9l6.5-4.5" stroke="#888" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="cd-text"><strong>Email</strong><span>comroussillon@gmail.com</span></div>
        </div>

        <div class="cd">
          <div class="cd-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 2c-.3 0-.6.2-.7.5L2 4c0 4.4 3.6 8 8 8l1.5-.3a.7.7 0 00.5-.7v-1.7l-2.5-.8-1 1.3C7 9.3 6.7 9 6.3 8.7l-.8-.8C5 7.3 4.7 7 4.5 6.5l1.3-1L5 3H3z" stroke="#888" stroke-width="1.1" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="cd-text"><strong>Téléphone</strong><span>07 81 59 70 34</span></div>
        </div>

        <div class="cd">
          <div class="cd-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M8 2C5.8 2 4 3.8 4 6c0 3 4 8 4 8s4-5 4-8c0-2.2-1.8-4-4-4z" stroke="#888" stroke-width="1.1"/>
              <circle cx="8" cy="6" r="1.3" stroke="#888" stroke-width="1.1"/>
            </svg>
          </div>
          <div class="cd-text"><strong>Adresse</strong><span>9 Espa. Méditerranée, 66000 Perpignan</span></div>
        </div>

        <div class="socials">
          <a href="https://www.instagram.com/com_roussillon/" target="_blank" class="social-btn" aria-label="Instagram">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <rect x="1.5" y="1.5" width="12" height="12" rx="3.5" stroke="#888" stroke-width="1.1"/>
              <circle cx="7.5" cy="7.5" r="2.5" stroke="#888" stroke-width="1.1"/>
              <circle cx="11" cy="4" r=".7" fill="#888"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61568516977029" target="_blank" class="social-btn" aria-label="Facebook">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <rect x="1.5" y="1.5" width="12" height="12" rx="3.5" stroke="#888" stroke-width="1.1"/>
              <path d="M8.5 7.5H7V11H5.5V7.5h-1V6h1V5.2A2 2 0 018.3 3H10v1.5H9a.5.5 0 00-.5.5V6H10L8.5 7.5z" fill="#888"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/comroussillon/" target="_blank" class="social-btn" aria-label="LinkedIn">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <rect x="1.5" y="1.5" width="12" height="12" rx="3.5" stroke="#888" stroke-width="1.1"/>
              <circle cx="5" cy="5.5" r=".8" fill="#888"/>
              <path d="M5 7V11M7.5 11V8.8A1.8 1.8 0 0111 9v2" stroke="#888" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M7.5 7V11" stroke="#888" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="fade-up">
        <form class="cr-form" id="contactForm" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="f250806b-c41b-4884-8143-816b48efbecf" />
          <input type="hidden" name="subject" value="Nouvelle demande de devis – Com Roussillon" />
          <input type="hidden" name="from_name" value="Com Roussillon" />
          <input type="checkbox" name="botcheck" style="display:none" />
          <div class="form-row">
            <input type="text" name="nom" placeholder="Prénom &amp; Nom" required />
            <input type="text" name="entreprise" placeholder="Entreprise (optionnel)" />
          </div>
          <input type="email" name="email" placeholder="Adresse email" required />
          <input type="tel" name="telephone" placeholder="Téléphone" />
          <select name="service" required>
            <option value="" disabled selected>Quel service vous intéresse ?</option>
            <option>Site web sur mesure</option>
            <option>Identité visuelle / logo</option>
            <option>Réseaux sociaux</option>
            <option>Supports d'impression</option>
            <option>Vêtements personnalisés</option>
            <option>Audit &amp; conseils</option>
            <option>Autre / je ne sais pas encore</option>
          </select>
          <textarea name="message" placeholder="Décrivez votre projet en quelques mots..." required></textarea>
          <button type="submit" id="submitBtn">Envoyer ma demande &nbsp;→</button>
          <p class="form-success" id="formSuccess">Merci ! On revient vers vous sous 24h. 👋</p>
          <p class="form-error" id="formError">Une erreur est survenue. Réessayez ou contactez-nous directement.</p>
        </form>
        <p class="form-legal">* Les informations renseignées dans ce formulaire serviront uniquement à répondre à votre demande et ne seront pas utilisées à des fins commerciales.</p>
      </div>

    </div>
  </div>
</section>

<style>
#contact { background: var(--bg-off) }
.contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 6rem; align-items: start }
.contact-info h2 {
  font-size: clamp(2rem, 4vw, 3rem); font-weight: 600;
  letter-spacing: -.03em; line-height: 1.1; color: var(--dark); margin-bottom: 1rem;
}
.contact-info > p {
  font-size: 17px; font-weight: 300; color: var(--light);
  line-height: 1.65; margin-bottom: 2.5rem; letter-spacing: -.01em;
}
.cd { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.3rem }
.cd-icon {
  width: 38px; height: 38px; background: #fff; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; box-shadow: 0 1px 3px rgba(0,0,0,.08);
}
.cd-text strong { display: block; font-size: 14px; font-weight: 500; color: var(--dark); margin-bottom: 2px }
.cd-text span { font-size: 14px; color: var(--light); font-weight: 300 }
.socials { display: flex; gap: .8rem; margin-top: 2rem }
.social-btn {
  width: 38px; height: 38px; background: #fff; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; box-shadow: 0 1px 3px rgba(0,0,0,.08); transition: box-shadow .2s;
}
.social-btn:hover { box-shadow: 0 3px 8px rgba(0,0,0,.12) }
.cr-form { display: flex; flex-direction: column; gap: .8rem }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .8rem }
.cr-form input,
.cr-form textarea,
.cr-form select {
  width: 100%; padding: .85rem 1.1rem;
  border: 0.5px solid #d2d2d7; border-radius: 12px;
  font-size: 15px; font-family: inherit; font-weight: 300;
  background: #fff; color: var(--dark); outline: none;
  transition: border-color .2s; appearance: none; -webkit-appearance: none; letter-spacing: -.01em;
}
.cr-form input:focus,
.cr-form textarea:focus,
.cr-form select:focus { border-color: var(--gold) }
.cr-form input::placeholder,
.cr-form textarea::placeholder { color: #c7c7cc }
.cr-form textarea { min-height: 130px; resize: none }
.cr-form button {
  align-self: flex-start; background: var(--dark); color: #fff; border: none;
  padding: .85rem 2rem; border-radius: 980px; font-size: 15px; font-weight: 500;
  letter-spacing: -.02em; cursor: pointer; font-family: inherit; transition: background .2s;
}
.cr-form button:hover { background: #333 }
.cr-form button:disabled { opacity: .6; cursor: not-allowed }
.form-success, .form-error { display: none; font-size: 14px; font-weight: 400; margin-top: .4rem; border-radius: 10px; padding: .7rem 1rem }
.form-success { background: #e8f5e9; color: #2e7d32 }
.form-error { background: #fdecea; color: #c62828 }
.form-legal { font-size: 12px; color: var(--light); font-weight: 300; margin-top: .8rem; line-height: 1.5 }

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; gap: 3rem }
  .form-row { grid-template-columns: 1fr }
}
</style>

<script>
const form = document.getElementById('contactForm') as HTMLFormElement | null
const btn = document.getElementById('submitBtn') as HTMLButtonElement | null
const success = document.getElementById('formSuccess')
const error = document.getElementById('formError')

form?.addEventListener('submit', async (e) => {
  e.preventDefault()
  if (!btn) return
  btn.disabled = true
  btn.textContent = 'Envoi en cours…'
  if (success) success.style.display = 'none'
  if (error) error.style.display = 'none'

  try {
    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: new FormData(form!)
    })
    const data = await res.json()
    if (data.success) {
      if (success) success.style.display = 'block'
      form!.reset()
    } else {
      if (error) error.style.display = 'block'
    }
  } catch {
    if (error) error.style.display = 'block'
  } finally {
    btn.disabled = false
    btn.innerHTML = 'Envoyer ma demande &nbsp;→'
  }
})
</script>
